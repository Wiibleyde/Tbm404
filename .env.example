# Postgres
POSTGRES_PASSWORD=change-me

# App + collector share this connection string.
# Host "postgres" is the compose service name; use "localhost" when running outside Docker.
DATABASE_URL=postgresql://tbm:change-me@localhost:5432/tbm404

# Collector
SIRI_URL=https://bdx.mecatran.com/utw/ws/siri/2.0/bordeaux/general-message.json?AccountKey=opendata-bordeaux-metropole-flux-gtfs-rt
GTFS_URL=https://bdx.mecatran.com/utw/ws/gtfsfeed/static/bordeaux?apiKey=opendata-bordeaux-metropole-flux-gtfs-rt
POLL_INTERVAL_SECONDS=180
GTFS_REFRESH_HOURS=24
